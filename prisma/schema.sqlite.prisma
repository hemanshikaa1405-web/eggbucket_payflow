// Use this schema for local development (no Supabase/Postgres required)
// Run: npx prisma generate --schema=prisma/schema.sqlite.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id         String         @id @default(uuid())
  name       String
  department String?
  phone      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  records    SalaryRecord[]
}

model SalaryRecord {
  id             String   @id @default(uuid())
  employeeId     String
  month          String
  trays          Int?
  bonus          Float?
  type           String?
  aqCount        Int?
  aqCost         Float?
  monthlySalary  Float?
  baseSalary     Float
  incentive      Float
  totalSalary    Float
  inputs         Json
  results        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([month])
}
